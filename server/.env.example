# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL on DigitalOcean)
DATABASE_URL=postgresql://user:password@localhost:5432/looped

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Storage — local for dev, switch to DO Spaces in production
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
CLIPS_DIR=./clips

# DigitalOcean Spaces (production)
# STORAGE_TYPE=spaces
# DO_SPACES_KEY=your_key
# DO_SPACES_SECRET=your_secret
# DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# DO_SPACES_BUCKET=looped-videos
# DO_SPACES_CDN=https://looped-videos.nyc3.cdn.digitaloceanspaces.com

# OpenAI Whisper (for transcription) — optional, falls back to ffmpeg
# OPENAI_API_KEY=your_openai_key

# Admin
ADMIN_EMAIL=admin@looped.com

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_PLAN_CODE=PLN_gr6k1k59trf0ne1
# Plan: Looped Pro · ₦16,800/month (displayed as $12/month on site)
# Currency: NGN

# Client URL (for Paystack redirect after payment)
CLIENT_URL=http://localhost:3000

